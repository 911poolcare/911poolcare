# Jobber OAuth (server-side only — never expose to the browser)
JOBBER_CLIENT_ID=
JOBBER_CLIENT_SECRET=
JOBBER_REFRESH_TOKEN=
# Optional — defaults to 2025-01-20
# JOBBER_GRAPHQL_VERSION=2025-01-20

# Vercel Blob — contact form photo/video uploads
# Connecting a Blob store in Vercel adds BLOB_STORE_ID automatically (OIDC on deploy).
# BLOB_READ_WRITE_TOKEN is optional — used for local dev after `vercel env pull`.
# BLOB_READ_WRITE_TOKEN=

# One-time setup:
# 1. Create an app at https://developer.getjobber.com with scopes:
#    clients, requests, properties (read/write)
# 2. Set OAuth callback URL to https://YOUR-DOMAIN/api/jobber/callback
# 3. Add JOBBER_CLIENT_ID and JOBBER_CLIENT_SECRET to Vercel
# 4. Visit https://YOUR-DOMAIN/api/jobber/authorize and approve access
# 5. Copy JOBBER_REFRESH_TOKEN from the success page into Vercel env vars
# 6. Redeploy

# Optional spam protection
TURNSTILE_SECRET_KEY=

# Google Places — server-side review import (scripts/import-google-reviews.mjs)
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=

# Google Places — browser address autocomplete on the contact form
# Use the same Google Cloud project; restrict this key to HTTP referrers (your domains).
# Enable: Maps JavaScript API, Places API, and Places API (New).
NEXT_PUBLIC_GOOGLE_PLACES_API_KEY=

# Google Analytics 4 — set in Vercel env vars to enable conversion tracking
NEXT_PUBLIC_GA_MEASUREMENT_ID=
